{
  "name": "@danylohotvianskyi/bobra-framework",
  "version": "0.1.3",
  "description": "Bobra Framework - Generic Cloudflare Workers Framework",
  "author": "Danylo Hotvianskyi",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danilgotvyansky/bobra.git",
    "directory": "framework"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "default": "./dist/logging/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/migrate": {
      "types": "./dist/db/migrate.d.ts",
      "default": "./dist/db/migrate.js"
    },
    "./network": {
      "types": "./dist/network/index.d.ts",
      "default": "./dist/network/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "default": "./dist/middleware/index.js"
    },
    "./batteries/auth": {
      "types": "./dist/batteries/auth/index.d.ts",
      "default": "./dist/batteries/auth/index.js"
    },
    "./batteries/search": {
      "types": "./dist/batteries/search/index.d.ts",
      "default": "./dist/batteries/search/index.js"
    },
    "./batteries/openapi": {
      "types": "./dist/batteries/openapi/index.d.ts",
      "default": "./dist/batteries/openapi/index.js"
    }
  },
  "files": [
    "dist",
    "batteries",
    "core",
    "db",
    "logging",
    "middleware",
    "network",
    "node",
    "scripts",
    "*.ts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@hono/valibot-validator": "^0.5.2",
    "@valibot/to-json-schema": "^1.3.0",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.44.3",
    "drizzle-valibot": "^0.4.2",
    "hono": "^4.11.9",
    "hono-openapi": "^0.4.8",
    "js-yaml": "^4.1.0",
    "pg": "^8.16.3",
    "postgres": "^3.2.0",
    "ts-node": "^10.9.2",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.4",
    "@types/pg": "^8.11.2",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.6.0"
  }
}